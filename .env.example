# Whisper ASR API — Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# === Server ===
HOST=0.0.0.0
PORT=8080
WORKERS=1

# === Model ===
# Path to faster-whisper CTranslate2 model directory
# If you have a HuggingFace model, use deploy.sh to convert it automatically
MODEL_PATH=models/whisper-large-v3-turbo-ct2
# Compute type: float16, int8_float16, int8
MODEL_COMPUTE_TYPE=float16
# Device: cuda or cpu
MODEL_DEVICE=cuda
# CUDA device index (0 for single GPU)
MODEL_DEVICE_INDEX=0

# === Model Download ===
# URL to download model archive from your bucket (tar.gz or zip)
MODEL_DOWNLOAD_URL=
# HuggingFace model ID (alternative to MODEL_DOWNLOAD_URL)
# deploy.sh will convert it to CTranslate2 format automatically
HF_MODEL_ID=

# === Audio Limits ===
# Maximum upload file size in bytes (default: 500MB)
MAX_UPLOAD_BYTES=524288000
# Maximum audio duration in seconds (default: 10 minutes)
MAX_AUDIO_DURATION=600
# Default language for transcription (set to "" for auto-detect)
DEFAULT_LANGUAGE=zh

# === VAD (Voice Activity Detection) ===
# Enable Silero VAD to filter non-speech segments
VAD_ENABLED=true
# VAD threshold (0.0-1.0, lower = more aggressive filtering)
VAD_THRESHOLD=0.5
# Minimum silence duration in ms for VAD split
VAD_MIN_SILENCE_DURATION_MS=500

# === Rate Limiting ===
# Requests per minute per IP (0 = disabled)
RATE_LIMIT_RPM=60
# Burst limit
RATE_LIMIT_BURST=10

# === Authentication ===
# Comma-separated list of valid API keys
# Leave empty to disable authentication
API_KEYS=

# === Logging ===
# Log level: debug, info, warning, error
LOG_LEVEL=info
# Log format: json (production) or console (development)
LOG_FORMAT=json

# === Temp Files ===
# Directory for temporary audio files
TEMP_DIR=/tmp/whisper_api

# === Proxy ===
# HTTP proxy for pip/model downloads (e.g., http://127.0.0.1:2080)
HTTP_PROXY=
HTTPS_PROXY=
