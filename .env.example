# Whisper ASR API — Environment Configuration
# Copy this file to .env and adjust values for your deployment.
#
# This service runs behind an API gateway in a trusted intranet.
# Authentication is handled upstream — no API keys needed at this layer.

# === Server ===
HOST=0.0.0.0
PORT=8080
# Comma-separated allowed origins for CORS (e.g. "https://app.example.com,https://admin.example.com")
# Leave empty to allow all origins (credentials will be disabled per W3C spec)
CORS_ORIGINS=

# === Model ===
# Path to faster-whisper CTranslate2 model directory
# If you have a HuggingFace model, use deploy.sh to convert it automatically
MODEL_PATH=models/whisper-large-v3-turbo-ct2
# Compute type: float16, int8_float16, int8
MODEL_COMPUTE_TYPE=float16
# Device: cuda or cpu
MODEL_DEVICE=cuda
# CUDA device index (0 for single GPU)
MODEL_DEVICE_INDEX=0

# === Model Download ===
# URL to download model archive from your bucket (tar.gz or zip)
MODEL_DOWNLOAD_URL=
# HuggingFace model ID (alternative to MODEL_DOWNLOAD_URL)
# deploy.sh will convert it to CTranslate2 format automatically
HF_MODEL_ID=

# === Audio Limits ===
# Maximum upload file size in bytes (default: 500MB)
MAX_UPLOAD_BYTES=524288000
# Maximum audio duration in seconds (default: 10 minutes)
MAX_AUDIO_DURATION=600
# Default language for transcription (set to "" for auto-detect)
DEFAULT_LANGUAGE=zh

# === VAD (Voice Activity Detection) ===
# Enable Silero VAD to filter non-speech segments
VAD_ENABLED=true
# VAD threshold (0.0-1.0, lower = more aggressive filtering)
VAD_THRESHOLD=0.5
# Minimum silence duration in ms for VAD split
VAD_MIN_SILENCE_DURATION_MS=500

# === Rate Limiting ===
# Requests per minute per IP (0 = disabled)
RATE_LIMIT_RPM=60
# Burst limit
RATE_LIMIT_BURST=10

# === Logging ===
# Log level: debug, info, warning, error
LOG_LEVEL=info
# Log format: json (production) or console (development)
LOG_FORMAT=json

# === Temp Files ===
# Directory for temporary audio files
TEMP_DIR=/tmp/whisper_api

# === Database (leave empty for stateless mode) ===
# PostgreSQL connection URL for asyncpg driver
# Format: postgresql+asyncpg://user:password@host:5432/ASR
# When empty, the service runs in backward-compatible stateless mode
DATABASE_URL=
# Connection pool size
DATABASE_POOL_SIZE=5
# Max overflow connections beyond pool_size
DATABASE_POOL_OVERFLOW=10

# === File Storage ===
# Permanent storage directory for uploaded audio files (DB-backed mode only)
STORAGE_PATH=/data/asr_storage

# === Task Scheduler (DB-backed mode only) ===
# Seconds between DB polls for PENDING tasks
TASK_POLL_INTERVAL=5
# Max retry attempts for failed tasks before giving up
TASK_MAX_RETRIES=3
# Max concurrent DB tasks processed by the scheduler
MAX_CONCURRENT_TASKS=2

# === Callback (DB-backed mode only) ===
# URL of the main backend callback endpoint for task completion notifications
# e.g. http://main-backend:8080/api/v1/callback/asr
MAIN_BACKEND_CALLBACK_URL=
# Max retry attempts for failed callbacks
CALLBACK_MAX_RETRIES=5
# Base delay in seconds for exponential backoff (delay * 2^attempt)
CALLBACK_RETRY_BASE_DELAY=1.0

# === Proxy ===
# HTTP proxy for pip/model downloads (e.g., http://127.0.0.1:2080)
HTTP_PROXY=
HTTPS_PROXY=
